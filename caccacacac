                                    if root and (root.Position - boneCamp.Position).Magnitude > 200 then
                                        TP1(boneCamp)
                                    end
                                end
                            end
                            Log("CDK_YAMA", "Dang thu Roll Xuc Xac Random Surprise...")
                            task.spawn(function()
                                for i = 1, 3 do
                                    pcall(function() CommF:InvokeServer("Bones", "Buy", 1, 1) end)
                                    task.wait(0.1)
                                end
                            end)
                        end
                    end
                end
            end
        end
    end)
    if not success then Log("ERROR", "Loi trong quest: " .. tostring(result)); return false end
    if success and result == "wait" then return "wait" end
    return false
end

local function questTushita(skipIfWaiting)
    local root = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local p = cdkProgress()
    if not p then return end
    local gd = tonumber(p.Good)
    if gd and gd >= 3 then Log("CDK_TUSHITA", "OK Done!", true); return true end
    if not gd then
        if skipIfWaiting then return "wait" end
        return false
    end

    local success, result = pcall(function()
        if gd == 1 or gd == 2 or gd == 0 then
            Log("CDK_TUSHITA", "Dang nhan nhiem vu moi...")
            cdkCmd("StartTrial", "Good")
            task.wait(1)
            return
        end
        if gd == -3 then
            Log("CDK_TUSHITA", "Q1: Boat Dealers (Dock Legend)")
            local dockCFs = {
                CFrame.new(-4602, 16, -2881), -- Castle on the Sea
                CFrame.new(-9531, 7, -8376),  -- Floating Turtle
                CFrame.new(5734, 18, 185),    -- Hydra Island
                CFrame.new(-312, 17, 5492)    -- Port Town
            }
            for _, pos in ipairs(dockCFs) do
                if not Active then return end
                
                -- Bay toi ben tau va CHO toi khi en noi (chong vu cancel tween lien tuc)
                while Active and (plr.Character.HumanoidRootPart.Position - pos.Position).Magnitude > 30 do
                    TP1(pos)
                    task.wait(1)
                end
                
                if CurTween then pcall(function() CurTween:Cancel() end) end
                
                -- a toi ben tau, tim NPC e noi chuyen
                local talkedToThisOne = false
                local waitCount = 0
                while Active and not talkedToThisOne and waitCount < 5 do
                    for _, npc in pairs(WS.NPCs:GetChildren()) do
                        if npc.Name:find("Luxury Boat Dealer") and npc.PrimaryPart then
                            pcall(function() plr.Character.HumanoidRootPart.CFrame = npc.PrimaryPart.CFrame end)
                            task.wait(0.5)
                            CommF:InvokeServer("CDKQuest", "BoatQuest", npc, "Check")
                            task.wait(0.5)
                            CommF:InvokeServer("CDKQuest", "BoatQuest", npc)
                            task.wait(0.5)
                            talkedToThisOne = true
                            break
                        end
                    end
                    if not talkedToThisOne then
                        task.wait(1)
                        waitCount = waitCount + 1
                    end
                end
                
                -- Kiem tra xem nhiem vu a xong chua
                local p = cdkProgress()
                if p and tonumber(p.Good) ~= -3 then
                    return
                end
            end
            
            -- Neu a quet het ben tau ma van o Q1, co the la do a lay uoc Fragment
            -- nhung game bat buoc phai tuong tac lai voi Scroll e qua Q2.
            Log("CDK_TUSHITA", "a check xong cac Boat Dealer. Gui lenh nhan Q2...")
            cdkCmd("StartTrial", "Good")
            task.wait(1)
            
        elseif gd == -4 then
            Log("CDK_TUSHITA", "Q2: Raid Castle (Sense of Duty)")
            local castlePos = CFrame.new(-5539, 314, -2972)
            
            -- Bay toi Castle truoc tien
            while Active and (plr.Character.HumanoidRootPart.Position - castlePos.Position).Magnitude > 300 do
                TP1(castlePos)
                task.wait(1)
            end
            if CurTween then pcall(function() CurTween:Cancel() end) end
            
            -- Doi map va quai spawn
            task.wait(2)
            
            -- Kiem tra xem co quai cua Pirate Raid khong
            local raidEnemyFound = false
            for _, e in pairs(Enemies:GetChildren()) do
                local eRoot = e:FindFirstChild("HumanoidRootPart")
                if alive(e) and eRoot and (eRoot.Position - castlePos.Position).Magnitude <= 2000 then
                    raidEnemyFound = true
                    killMob(e, function() return Active end, false, "Tushita")
                    break
                end
            end

            -- Neu khong co quai, dung cho
            if not raidEnemyFound then
                Log("CDK_TUSHITA", "ang ung cho Raid Hai Tac tai Lau ai...")
                task.wait(2)
                return "wait"
            end
            
            -- Thu StartTrial e check qua bai
            local p = cdkProgress()
            if p and tonumber(p.Good) == -4 and not raidEnemyFound then
                cdkCmd("StartTrial", "Good")
            end
        elseif gd == -5 then
            if not _G.SoullessStarted then
                _G.SoullessStarted = true
                cdkCmd("StartTrial", "Good")
                task.wait(1.5)
            end
            
            Log("CDK_TUSHITA", "Q3: Heavenly Dimension (Soulless)")
            local heaven = WS.Map:FindFirstChild("HeavenlyDimension")
            local root = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")

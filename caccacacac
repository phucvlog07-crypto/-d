local function equipName(name)
    if not name then return end
    local c = plr.Character
    if not c or not c:FindFirstChild("Humanoid") then return end
    -- a cam roi thi bo qua
    local held = c:FindFirstChildOfClass("Tool")
    if held and held.Name == name then return end
    local t = plr.Backpack:FindFirstChild(name)
    if t then c.Humanoid:EquipTool(t) end
end

local function equipBestSword()
    local c = plr.Character
    if not c or not c:FindFirstChild("Humanoid") then return end
    
    if has("Tushita") then equipName("Tushita"); return end
    if has("Yama") then equipName("Yama"); return end
    
    local types = {"Melee", "Sword"}
    for _, typeName in ipairs(types) do
        for _, t in pairs(plr.Backpack:GetChildren()) do
            if t:IsA("Tool") and t.ToolTip == typeName then
                c.Humanoid:EquipTool(t); return
            end
        end
    end
end


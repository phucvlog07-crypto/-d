                    while Active and alive(bm) and (plr.Character.HumanoidRootPart.Position - bm.HumanoidRootPart.Position).Magnitude > 100 do
                        TP1(bm.HumanoidRootPart.CFrame)
                        task.wait(1)
                    end
                    if CurTween then pcall(function() CurTween:Cancel() end) end
                    
                    if alive(bm) then
                        killMob(bm, function() return Active end, false, "Tushita")
                    end
                else
                    -- Cake Queen khong co mat (chua spawn hoac vua bi chet)
                    local portalPos = CFrame.new(-655, 381, -10667)
                    
                    Log("CDK_TUSHITA", " ang toi Cong Thien uong / Cho Cong mo...")
                    
                    local inHeaven = false
                    -- Thu tiep can Cong hoac cho trong toi a 20 giay (Danh cho truong hop vua giet xong, ung cho Cong)
                    for t = 1, 20 do
                        if not Active or findMob("Cake Queen") then break end
                        
                        local dist = (plr.Character.HumanoidRootPart.Position - portalPos.Position).Magnitude
                        if dist > 1000 then
                            -- Neu o ao khac (rat xa), dung TP1 e bay qua tu tu
                            TP1(portalPos)
                        else
                            -- Neu a toi ao Banh (< 1000 studs), Dich Chuyen Tuc Thoi thang vao Cong luon!
                            -- (Khong dung TP1 o khoang cach ngan e tranh bi ket vo han)
                            if CurTween then pcall(function() CurTween:Cancel() end) end
                            _G._CDK_TP_Active = true
                            getCDKBlock().CFrame = portalPos
                        end
                        task.wait(1)
                        
                        -- Kiem tra xem a bi hut vao Thien uong chua
                        local heaven2 = WS.Map:FindFirstChild("HeavenlyDimension")
                        if heaven2 and heaven2:FindFirstChild("Spawn") and (plr.Character.HumanoidRootPart.Position - heaven2.Spawn.Position).Magnitude <= 1000 then
                            inHeaven = true
                            break
                        end
                    end
                    
                    if inHeaven then
                        return -- a vao Thien uong, vong lap sau se tu i thap uoc!
                    end
                    
                    -- Neu sau 20s khong vao uoc Thien uong va cung khong co Big Mom -> Cong khong ton tai (Boss chua spawn), Hop!
                    if not findMob("Cake Queen") then
                        Log("CDK_TUSHITA", "FIRE Khong co Cong / Khong co Big Mom! ang Hop Server...")
                        hop()
                        task.wait(10)
                        return "wait"
                    end
                end
            end
        end
        return "wait"
    end)
    if success and result == "wait" then return "wait" end
    return false
end

local function p5_cdk()
    Log("CDK", "Bat dau CDK Quest!", true)
    if inBag("Cursed Dual Katana") then Log("CDK", "OK Da co CDK!", true); return true end

    cdkCmd("OpenDoor"); task.wait(0.5)
    cdkCmd("OpenDoor", true); task.wait(1)
    


    local yOk, tOk = false, false
    while Active and not (yOk and tOk) do
        local pr = cdkProgress()
        if pr then
            if tonumber(pr.Evil) and tonumber(pr.Evil) >= 3 then yOk = true end
            if tonumber(pr.Good) and tonumber(pr.Good) >= 3 then tOk = true end
        end

        if not yOk then
            local status = questYama(false)
            if status == true then yOk = true end
        elseif not tOk then
            local status = questTushita(false)
            if status == true then tOk = true end
        end
        task.wait(1)
    end

    if yOk and tOk then
        Log("CDK", "FIREFIRE FINAL BOSS FIREFIRE", true)
        while Active and not inBag("Cursed Dual Katana") do
            local boss = findMob("Cursed Skeleton Boss")
            if boss then
                Log("CDK", "ATK Final Boss!", true)
                equipBestSword()
                killMob(boss, function() return Active and not inBag("Cursed Dual Katana") end, false, "Tushita")
            else
                TP1(CFrame.new(-12318, 602, -6539))
                task.wait(1)
                
                pcall(function()
                    if workspace.Map:FindFirstChild("Turtle") and workspace.Map.Turtle:FindFirstChild("Cursed") and workspace.Map.Turtle.Cursed:FindFirstChild("BossDoor") then
                        TP1(workspace.Map.Turtle.Cursed.BossDoor.CFrame)
                    end
                end)
                task.wait(0.5)
                
                cdkCmd("Progress", "Good")
                cdkCmd("Progress", "Evil")
                cdkCmd("StartTrial", "Boss")
                task.wait(2)
            end
            task.wait(1)
        end
    end
    return inBag("Cursed Dual Katana")
end


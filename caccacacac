local function TP1(pos, condition)
    if not playerOk() then return end
    condition = condition or function() return true end
    local target = typeof(pos) == "CFrame" and pos or CFrame.new(pos)

    local root = plr.Character.HumanoidRootPart
    getCDKBlock().CFrame = root.CFrame
    _G._CDK_TP_Active = true

    pcall(function()
        if plr.Character.Humanoid.Sit then
            plr.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end)

    local function tweenTo(subTarget)
        local d = (subTarget.Position - getCDKBlock().Position).Magnitude
        if d < 5 then return end
        local tweenTime = d / 300
        
        if CurTween then pcall(function() CurTween:Cancel(); CurTween = nil end) end
        CurTween = TweenSvc:Create(getCDKBlock(), TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = subTarget})
        CurTween:Play()
        
        local start = tick()
        repeat
            task.wait(0.1)
        until not CurTween or CurTween.PlaybackState ~= Enum.PlaybackState.Playing or not playerOk() or not condition() or not Active or tick() - start > 60

        if CurTween then pcall(function() CurTween:Cancel(); CurTween = nil end) end
        getCDKBlock().CFrame = subTarget
    end

    tweenTo(target)
    _G._CDK_TP_Active = false
end



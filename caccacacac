                task.wait(0.5)
                Log("CDK_TUSHITA", "ATK Danh quai trong Thien Duong!")
                for _, e in pairs(Enemies:GetChildren()) do
                    if alive(e) and (e.PrimaryPart.Position - heaven.Spawn.Position).Magnitude <= 300 then
                        -- oi false thanh true e KHONG keo quai, giu quai o duoi at!

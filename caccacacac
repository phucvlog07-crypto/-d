-- 
--  UTILITY FUNCTIONS
-- 
local function alive(entity)
    if not entity or not entity.Parent then return false end
    local h = entity:FindFirstChild("Humanoid")
    return h and h.Health > 0 and entity:FindFirstChild("HumanoidRootPart") ~= nil
end

local function playerOk()
    local c = plr.Character
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0 and c:FindFirstChild("HumanoidRootPart") ~= nil
end

local function dist2D(a, b)
    return (Vector3.new(a.X, 0, a.Z) - Vector3.new(b.X, 0, b.Z)).Magnitude
end

local function dist3D(target)
    local c = plr.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return math.huge end
    local pos = typeof(target) == "CFrame" and target.Position
        or typeof(target) == "Vector3" and target
        or (typeof(target) == "Instance" and target:FindFirstChild("HumanoidRootPart") and target.HumanoidRootPart.Position)
        or nil
    if not pos then return math.huge end
    return (c.HumanoidRootPart.Position - pos).Magnitude
end

local function has(name)
    return plr.Backpack:FindFirstChild(name)
        or (plr.Character and plr.Character:FindFirstChild(name))
end

local function inBag(name)
    if has(name) then return true end
    local ok, inv = pcall(function() return CommF:InvokeServer("getInventory") end)
    if not ok or type(inv) ~= "table" then return false end
    for _, v in pairs(inv) do
        if type(v) == "table" and v.Name == name then return true end
    end
    return false
end

local function mastery(name)
    local t = has(name)
    if t and typeof(t) == "Instance" and t:FindFirstChild("Level") then return t.Level.Value end
    local ok, inv = pcall(function() return CommF:InvokeServer("getInventory") end)
    if not ok or type(inv) ~= "table" then return 0 end
    for _, v in pairs(inv) do
        if type(v) == "table" and v.Name == name then return tonumber(v.Mastery) or 0 end
    end
    return 0
end

local function loadItem(name)
    if not has(name) then pcall(function() CommF:InvokeServer("LoadItem", name) end); task.wait(0.5) end
end


                bv.Name = "_BV"; bv.MaxForce = Vector3.new(1e9,1e9,1e9)
                bv.Velocity = Vector3.zero; bv.Parent = mRoot
            else
                mRoot._BV.Velocity = Vector3.zero
            end
        end)
        pcall(function() sethiddenproperty(plr, "SimulationRadius", math.huge) end)
    end
end

-- 
--  KILL ENEMY  Bay toi mob TAI CHO + ung tren au
--  Mob o au thi anh o o, khong keo i xa
-- 
local HOVER_Y = 35
local MIN_Y   = 50

local function bringMob(targetMob)
    if not targetMob or not targetMob:FindFirstChild("HumanoidRootPart") then return end
    local posMon = targetMob.HumanoidRootPart.CFrame
    local count = 0
    
    pcall(function() sethiddenproperty(plr, "SimulationRadius", math.huge) end)

    for _, v in pairs(WS.Enemies:GetChildren()) do
        if v.Name == targetMob.Name and v ~= targetMob then
            local hum = v:FindFirstChild("Humanoid")
            local pp = v:FindFirstChild("HumanoidRootPart")
            if hum and pp and hum.Health > 0 then
                if (pp.Position - posMon.Position).Magnitude <= 350 then
                    count = count + 1
                    if count >= 6 then break end
                    
                    pcall(function()
                        pp.CanCollide = false
                        hum.WalkSpeed = 0
                        hum.JumpPower = 0
                        if hum:FindFirstChild("Animator") then hum.Animator:Destroy() end
                        
                        pp.CFrame = posMon
                        pp.AssemblyLinearVelocity = Vector3.zero
                        pp.AssemblyAngularVelocity = Vector3.zero
                    end)
                end
            end
        end
    end
end

local function killMob(enemy, check, noBring, weaponName)
    if not alive(enemy) then return end
    pcall(function() enemy:AddTag("realmob") end)

    if dist3D(enemy) > 50 then
        Log(Phase, "Bay toi " .. enemy.Name .. "...")
        TP1(enemy.HumanoidRootPart.CFrame * CFrame.new(0, HOVER_Y, 0),
            function() return alive(enemy) and dist3D(enemy) > 20 end)
    end

    -- Removed dist3D > 50 abort condition to prevent running away when knocked back

    local function equipWeapon()
        if weaponName then
            loadItem(weaponName)
            equipName(weaponName)
        else
            equipBestSword()
        end
    end

    equipWeapon()
    local lastEquip = tick()
    setVelocity(true)
    local hoverTween = nil
    
    local v3v4Loop = true
    task.spawn(function()
        local vim = game:GetService("VirtualInputManager")
        while v3v4Loop and Active do
            pcall(function()
                vim:SendKeyEvent(true, Enum.KeyCode.T, false, game)
                task.wait(0.1)
                vim:SendKeyEvent(false, Enum.KeyCode.T, false, game)
                task.wait(0.5)
                vim:SendKeyEvent(true, Enum.KeyCode.Y, false, game)
                task.wait(0.1)
                vim:SendKeyEvent(false, Enum.KeyCode.Y, false, game)
            end)
            task.wait(5)
        end
    end)
    
    local attackConn = RunSvc.Heartbeat:Connect(function()
        if Active and alive(enemy) and playerOk() then
            pcall(function() fastAttack() end)
            pcall(function()
                local eHum = enemy:FindFirstChild("Humanoid")
                local eRoot = enemy:FindFirstChild("HumanoidRootPart")
                if eHum then eHum.WalkSpeed = 0; eHum.JumpPower = 0 end
                if eRoot then
                    eRoot.CanCollide = false
                    eRoot.Velocity = Vector3.new(0,0,0)
                end
            end)
            if not noBring then pcall(function() bringMob(enemy) end) end
        end
    end)

    repeat
        task.wait(0.15)
        if not Active then break end
        if check and not check() then break end
        if not playerOk() then task.wait(2); continue end
        if not alive(enemy) then break end
        local ePos = enemy.HumanoidRootPart.Position
        local hoverCF
        if enemy.Name:find("Cake Queen") or enemy.Name:find("Boss") then
            -- May thich bay cao thi tao cho bay thang len troi 45 met luon
            local safeY = math.max(ePos.Y + 45, MIN_Y)
            hoverCF = CFrame.new(ePos.X, safeY, ePos.Z)
        else
            -- Quai thuong thi ung tren au. Neu noBring = true (anh tu xa) thi bay len cao 25m
            local hoverDist = noBring and 25 or HOVER_Y
            local safeY = math.max(ePos.Y + hoverDist, MIN_Y)
            hoverCF = CFrame.new(ePos.X, safeY, ePos.Z)
        end

        pcall(function()
            local root = plr.Character.HumanoidRootPart
            _G._CDK_TP_Active = true
            
            local d = (getCDKBlock().Position - hoverCF.Position).Magnitude
            if d > 200 then
                if hoverTween then pcall(function() hoverTween:Cancel() end) end
                TP1(hoverCF, function() return alive(enemy) end)
            elseif d > 3 then
                if hoverTween then pcall(function() hoverTween:Cancel() end) end
                local tweenTime = math.clamp(d / 250, 0.1, 1.5)
                hoverTween = TweenSvc:Create(getCDKBlock(),
                    TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
                    {CFrame = hoverCF})
                hoverTween:Play()
            else
                if hoverTween then pcall(function() hoverTween:Cancel() end) end
                getCDKBlock().CFrame = hoverCF
            end
            root.AssemblyLinearVelocity = Vector3.zero
            noClip()
        end)
        if tick() - lastEquip > 5 then
            equipWeapon()
            lastEquip = tick()
        end
    until not Active or not alive(enemy) or (check and not check())
    --_G._CDK_TP_Active = false
    if hoverTween then pcall(function() hoverTween:Cancel() end) end
    if attackConn then pcall(function() attackConn:Disconnect() end) end
    v3v4Loop = false
    setVelocity(false)
end

local function findMob(names)
    if type(names) == "string" then names = {names} end
    for _, src in ipairs({RS, Enemies}) do
        for _, child in pairs(src:GetChildren()) do
            if child:IsA("Model") and alive(child) then
                for _, n in ipairs(names) do
                    if child.Name == n then return child end
                end
            end
        end
    end
    return nil
end

-- 
--  SERVER HOP (tu hop.txt  hoat ong tot)
-- 
local hopping = false
local hopRetry = 0

-- [ HAM HOP TOI UU 1-REQUEST ]
local isHopping = false
local ServerBrowser = RS:WaitForChild("__ServerBrowser")
local function hop()
    if isHopping then return end
    isHopping = true
    Log("HOP", "Dang tim server moi...", true)

    local function getServersFromAPI()
        local servers = {}
        local cursor = ""
        local ok = false
        repeat
            local s, r = pcall(function() return HttpSvc:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100&cursor=" .. cursor)) end)
            if s and r and type(r) == "table" and r.data then
                ok = true
                for _, sv in pairs(r.data) do
                    if type(sv) == "table" and sv.playing and sv.id and sv.playing >= 1 and sv.playing <= 10 and sv.id ~= game.JobId then
                        table.insert(servers, sv)
                        if #servers >= 10 then break end
                    end
                end
                cursor = r.nextPageCursor or ""
            else
                cursor = ""
            end
        until cursor == "" or #servers >= 10
        if ok and #servers > 0 then return servers end
        return nil
    end

    local function getServersFromBrowser()
        local collectedServers = {}
        for page = 1, 100 do
            local success, data = pcall(function() return ServerBrowser:InvokeServer(page) end)
            if success and type(data) == "table" then
                for jobId, info in pairs(data) do
                    if jobId ~= game.JobId and type(info) == "table" then
                        table.insert(collectedServers, {id = jobId, playing = info.Count or 0})
                    end
                end
                if #collectedServers >= 30 then break end
            end
            task.wait(0.05)
        end
        if #collectedServers > 0 then
            table.sort(collectedServers, function(a, b) return a.playing < b.playing end)
            local top10 = {}
            for i = 1, math.min(10, #collectedServers) do table.insert(top10, collectedServers[i]) end
            return top10
        end
        return nil
    end

    task.spawn(function()
        local teleportFailed = false
        TpSvc.TeleportInitFailed:Connect(function() teleportFailed = true end)
        while true do
            local servers = getServersFromAPI()
            if not servers then
                Log("HOP", "API bi gioi han, dung ServerBrowser...", true)
                servers = getServersFromBrowser()
            end
            if servers and #servers > 0 then
                local pick = servers[math.random(1, #servers)]
                Log("HOP", "Dang ket noi Server moi...", true)
                teleportFailed = false
                pcall(function() ServerBrowser:InvokeServer("teleport", pick.id) end)
                pcall(function() TpSvc:TeleportToPlaceInstance(game.PlaceId, pick.id, plr) end)
                local waitTime = 0
                while waitTime < 15 do
                    if teleportFailed then break end
                    task.wait(1)

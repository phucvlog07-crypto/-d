local BRING_SAFE = 25  -- chi gom mob trong 25 studs (trong vung spawn)

local function bringClose(anchorPos)
    if not playerOk() then return end
    -- Chi gom mob a o gan san  don lai 1 cho duoi chan
    local bringTarget = CFrame.new(anchorPos.X, anchorPos.Y - 15, anchorPos.Z)
    for _, mob in pairs(Enemies:GetChildren()) do
        if BossNames[mob.Name] then continue end
        if not alive(mob) then continue end
        local mRoot = mob.HumanoidRootPart
        local d = (mRoot.Position - anchorPos).Magnitude
        if d > BRING_SAFE then continue end  -- chi mob gan
        pcall(function()
            mRoot.CFrame = bringTarget
            mRoot.CanCollide = false
            mRoot.AssemblyLinearVelocity = Vector3.zero
            mRoot.AssemblyAngularVelocity = Vector3.zero

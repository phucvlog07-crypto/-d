local SpinAngle, SpinTick = 0, tick()
local function spinPos(center)
    if SpinAngle > 6000 then SpinAngle = 60 end
    SpinAngle = SpinAngle + (tick() - SpinTick > 0.5 and 90 or 0)
    SpinTick = tick() - SpinTick > 0.5 and tick() or SpinTick
    return CFrame.new(
        center.X + math.sin(math.rad(SpinAngle + 360)) * 30,
        center.Y,
        center.Z + math.cos(math.rad(SpinAngle + 360)) * 30
    )
end

-- 
--  FAST ATTACK  RegisterAttack(0) + RegisterHit
--  User-verified: A TEST HOAT ONG
-- 
local RegAttack = Net:WaitForChild("RE/RegisterAttack", 10)
local RegHit    = Net:WaitForChild("RE/RegisterHit", 10)

local LastAttack = 0

local function fastAttack()
    local c = plr.Character
    if not c then return end

    local tool = c:FindFirstChildOfClass("Tool")
    if not tool then return end

    -- Tranh spam remote qua nhanh gay kick (Error 267)
    local cd = tool:FindFirstChild("Cooldown") and tool.Cooldown.Value or 0.25
    if tick() - LastAttack < cd then return end
    LastAttack = tick()

    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Thu thap targets trong range (giong getHead)
    local hitTable = {}
    for _, mob in pairs(Enemies:GetChildren()) do
        if mob ~= c and alive(mob) then
            local d = (hrp.Position - mob.HumanoidRootPart.Position).Magnitude
            if d <= 60 then
                table.insert(hitTable, { mob, mob.HumanoidRootPart })
            end
        end
    end
    if #hitTable == 0 then return end

    -- Tach firstTarget khoi hitTable
    local firstTarget = table.remove(hitTable, 1)[2]

    -- Khoi tao Attack
    RegAttack:FireServer()

    -- Kiem tra Thread/Anti-cheat moi cua game
    local useThread = false
    local hitFn = nil
    pcall(function() useThread = require(RS.Modules.Flags).COMBAT_REMOTE_THREAD or false end)
    pcall(function() hitFn = getrenv()._G.SendHitsToServer end)

    if useThread and hitFn then
        local v1 = tostring(plr.UserId):sub(2,4) .. tostring(coroutine.running()):sub(11,15)
        hitFn(firstTarget, hitTable, nil, v1)
    else
        pcall(function() RegHit:FireServer(firstTarget, hitTable) end)
    end
end


                    isGateOpen = true
                end
                
                if isGateOpen then
                    Log("CDK_TUSHITA", "OK Cong a mo! Bay vao cong e hoan thanh nhiem vu...")
                    if CurTween then pcall(function() CurTween:Cancel() end) end
                    _G._CDK_TP_Active = true
                    getCDKBlock().CFrame = heaven.Exit.CFrame
                    root.CFrame = heaven.Exit.CFrame
                    task.wait(1)
                    return "wait"
                end
                
                Log("CDK_TUSHITA", "FIREFIRE Da len Thien Duong! Thap duoc...")
                
                -- May noi chuan cmnr! Game no co StreamingEnabled, ung xa qua no eo load cai nut E!
                -- Tao a tim uoc toa o UNG cua cay uoc so 3 tu 1 file script xin khac.
                local torches = {
                    CFrame.new(-22529.6, 5275.8, 3873.6),
                    CFrame.new(-22637.3, 5281.4, 3749.3),
                    CFrame.new(-22791.1, 5277.2, 3764.6) -- Toa o chuan xac cua cay thu 3!
                }
                
                for i, pos in ipairs(torches) do
                    Log("CDK_TUSHITA", "FIREFIRE ang bay toi thap uoc so " .. i .. "...")
                    
                    if CurTween then pcall(function() CurTween:Cancel() end) end
                    _G._CDK_TP_Active = true
                    getCDKBlock().CFrame = pos
                    root.CFrame = pos
                    
                    task.wait(0.5) -- oi game load chunk e hien nut E
                    
                    -- ung tai cho quet lua
                    for k = 1, 5 do
                        if not Active then break end
                        getCDKBlock().CFrame = pos
                        for _, v in pairs(heaven:GetDescendants()) do
                            if v:IsA("ProximityPrompt") and v.Parent and v.Parent:IsA("BasePart") then
                                if (v.Parent.Position - pos.Position).Magnitude < 30 then
                                    pcall(function() fireproximityprompt(v) end)
                                end

local Angle = 40
local lastChange = tick()
local function CaculateCircreDirection(Position)
    if Angle > 50000 then Angle = 60 end
    Angle = Angle + ((tick() - lastChange) > 0.4 and 80 or 0)
    if tick() - lastChange > 0.4 then lastChange = tick() end
    local function roundVec(vec)
        return Vector3.new(math.floor(vec.X/10)*10, math.floor(vec.Y/10)*10, math.floor(vec.Z/10)*10)
    end
    local sum = Position + Vector3.new(math.cos(math.rad(Angle)) * 40, 0, math.sin(math.rad(Angle)) * 40)
    return CFrame.new(roundVec(sum))
end

local GrabDebounce = 0
local function GrabMob(MobName)
    if GrabDebounce == os.time() then return end
    GrabDebounce = os.time()

    pcall(sethiddenproperty, LocalPlayer, "SimulationRadius", math.huge)

    local MidPoint, Count = Vector3.zero, 0
    local MobsTable = {}

    for _, Mon in Services.Workspace.Enemies:GetChildren() do
        if Mon.Name == MobName and Mon:FindFirstChild("Humanoid") and Mon.Humanoid.Health > 0 then
            local MonPosition = Mon.HumanoidRootPart.Position
            if MonPosition and isnetworkowner(Mon.PrimaryPart) then
                Count = Count + 1
                Mon:SetAttribute("OldPosition", Mon:GetAttribute("OldPosition") or MonPosition)
                MidPoint = MidPoint + MonPosition
                table.insert(MobsTable, Mon)
            end
        end
    end

    if Count == 0 then return end
    MidPoint = CFrame.new(MidPoint / Count)

    for _, Mon in ipairs(MobsTable) do
        pcall(function()
            if Mon:GetAttribute("IgnoreGrab") then return end
            local RootPart = Mon:FindFirstChild("HumanoidRootPart")
            if not RootPart then return end

            local bv = RootPart:FindFirstChild("FarmingVelocity") or Instance.new("BodyVelocity")
            bv.Name = "FarmingVelocity"
            bv.MaxForce = Vector3.new(4000, 4000, 4000)
            bv.Velocity = Vector3.zero
            bv.Parent = RootPart

            local bp = RootPart:FindFirstChild("FarmingPosition") or Instance.new("BodyPosition")
            bp.Name = "FarmingPosition"
            bp.MaxForce = Vector3.new(4000, 4000, 4000)
            bp.P = 4.12
            bp.D = 1000
            bp.Parent = RootPart

            Mon:SetAttribute("IsGrabbed", true)
            Mon.HumanoidRootPart.CFrame = MidPoint
        end)
    end
end

local function GetCakePrince()
    local mob = Enemies["Cake Prince"]
    if mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
        return mob
    end
    return nil
end

local function AttackCakePrince(mob)
    while task.wait() do
        local MobHumanoid = mob:FindFirstChild("Humanoid")
        local MobHRP = mob:FindFirstChild("HumanoidRootPart")

        if not MobHumanoid or MobHumanoid.Health <= 0 then
            return true
        end

        TweenTo(CaculateCircreDirection(MobHRP.CFrame) + Vector3.new(0, 35, 0))

        local dist = CaculateDistance(MobHRP.Position + Vector3.new(0, 35, 0))
        if dist < 150 then
            GrabMob("Cake Prince")
            EquipTool("Melee")
            Attack()
        end
    end

    return false
end

local function fetchServers()
    local url = "http://mbasic7.pikamc.vn:25082/api/name=cakeprince?apikey=CONCACDUMAMAY"
    local success, result = pcall(function()
        local raw = request({Url = url, Method = "GET"})
        return HttpService:JSONDecode(raw.Body)
    end)
    if not success then return {} end
    if not result or not result.success
    or type(result.data) ~= "table"
    or type(result.data.data) ~= "table" then
        return {}
    end
    return result.data.data
end

local function hopToServer()
    local servers = fetchServers()
    if #servers == 0 then
        return false
    end

    local validServers = {}
    for _, server in ipairs(servers) do
        local jobId  = server.jobid
        local placeId = tostring(server.placeid or "")
        if jobId
            and jobId ~= game.JobId
            and placeId == tostring(game.PlaceId)
        then
            table.insert(validServers, server)
        end
    end

    if #validServers == 0 then
        return false
    end

    local target = validServers[math.random(1, #validServers)]
    ReplicatedStorage:WaitForChild("__ServerBrowser"):InvokeServer("teleport", target.jobid)
    return true
end


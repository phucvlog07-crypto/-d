local function urlencode(str)
    str = tostring(str)
    str = str:gsub("\n", "\r\n")
    str = str:gsub("([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
    return str
end

local function CaculateDistance(Origin, Destination)
    Destination = Destination or LocalPlayer.Character.HumanoidRootPart.CFrame
    local function conv(v)
        return Vector3.new(v.X, v.Y, v.Z)
    end
    return (conv(Origin) - conv(Destination)).Magnitude
end

local function ConvertTo(Type, Instance)
    return Type.new(Instance.X, Instance.Y, Instance.Z)
end

local Portals = {} -- Fill this with Sea 3 portal Vector3s if you have them!
local function GetPortal(Position)
    local Nearest, Current = 9e9, nil
    for _, Portal in pairs(Portals) do
        local Dist1 = CaculateDistance(Portal, Position)
        if Dist1 < (CaculateDistance(Position) - 300) and Dist1 < Nearest then
            Nearest = Dist1
            Current = Portal
        end
    end

    if Current then
        local CommF_ = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
        CommF_:InvokeServer("requestEntrance", Current)
        return true
    end
    return false
end

local TweenInstance = nil
local function TweenTo(Position)
    if not Position then return end
    Position = typeof(Position) ~= "CFrame" and ConvertTo(CFrame, Position) or Position

    if CaculateDistance(Position) > 500 then
        if GetPortal(Position) then
            task.wait(0.5)
        end
    end

    if TweenInstance then
        pcall(function() TweenInstance:Cancel() end)
    end

    for _, Part in LocalPlayer.Character:GetDescendants() do
        if Part:IsA("BasePart") then
            Part.CanCollide = false
        end
    end

    local Head = LocalPlayer.Character:WaitForChild("Head")
    if not Head:FindFirstChild("cakehop_bv") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "cakehop_bv"
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        bv.Velocity = Vector3.zero
        bv.Parent = Head
    end

    Position = CFrame.new(Position.Position)
    local PlayerPos = LocalPlayer.Character.HumanoidRootPart.CFrame
    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(PlayerPos.X, Position.Y, PlayerPos.Z)

    local Dist = CaculateDistance(LocalPlayer.Character.HumanoidRootPart.CFrame, Position)
    TweenInstance = Services.TweenService:Create(
        LocalPlayer.Character.HumanoidRootPart,
        TweenInfo.new(Dist / (Dist < 18 and 25 or 330), Enum.EasingStyle.Linear),
        {CFrame = Position}
    )
    TweenInstance:Play()
end


local function CheckAPIAndJoin()
    if hasGodChalice() or hasSweetChalice() then return false end
    local baseUrl = "https://daybreak-frosting-bobbing.ngrok-free.dev"
    getgenv().FailedAPIJoins = getgenv().FailedAPIJoins or {}
    
    local myJobId = game.JobId
    local urls = {
        baseUrl .. "/api/data/doughking",
        baseUrl .. "/api/data/ripindra"
    }
    local apiError = false
    local foundAnyBoss = false
    
    for _, url in pairs(urls) do
        local success, res = pcall(function()
            return request({
                Url = url,
                Method = "GET",
                Headers = {["Authorization"] = "CONCACDUMAMAY", ["Bypass-Tunnel-Reminder"] = "true"}
            })
        end)
        if success and res and res.StatusCode == 200 then
            local data = game:GetService("HttpService"):JSONDecode(res.Body)
            if data and data.data and type(data.data) == "table" then
                local events = {}
                if data.data[1] then
                    events = data.data
                elseif data.data.JobId then
                    events = { data.data }
                end
                
                for _, event in ipairs(events) do
                    if event and event.JobId and event.JobId ~= "" then
                        foundAnyBoss = true
                        if event.JobId == myJobId then
                            local bType = "Dough King"
                            if string.find(url, "ripindra") then bType = "Rip Indra" end
                            return "IN_SERVER", bType
                        else
                            local targetJob = event.JobId
                            local targetPlace = tonumber(event.PlaceId) or tonumber(event.PlaceID) or 7449423635
                            
                            local fails = getgenv().FailedAPIJoins[targetJob] or 0
                            if fails < 3 then
                                getgenv().FailedAPIJoins[targetJob] = fails + 1
                                getgenv().CurrentFarmTask = 'Found Boss on API! Joining...'
                                
                                pcall(function()
                                    local sb = game:GetService("ReplicatedStorage"):WaitForChild("__ServerBrowser", 3)
                                    if sb then
                                        sb:InvokeServer("teleport", targetJob)
                                    end
                                end)
                                
                                task.spawn(function()
                                    task.wait(2)
                                    pcall(function()
                                        game:GetService("TeleportService"):TeleportToPlaceInstance(targetPlace, targetJob, game.Players.LocalPlayer)
                                    end)
                                end)
                                
                                task.wait(15)
                                return true
                            end
                        end
                    end
                end
            end
        else
            apiError = true
        end
    end
    
    if apiError and not foundAnyBoss then
        return "API_ERROR"
    end
    return false
end


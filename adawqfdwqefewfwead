local DynamicMobSpawns = {}

local function InitializeMobSpawns()
    local spawnGroups = {}
    local enemySpawnsFolder = workspace:FindFirstChild("_WorldOrigin") and workspace._WorldOrigin:FindFirstChild("EnemySpawns")
    if not enemySpawnsFolder then return end
    for _, spawnNode in pairs(enemySpawnsFolder:GetChildren()) do
        local cleanName = RemoveLevelTitle(spawnNode.Name)
        if not spawnGroups[cleanName] then
            spawnGroups[cleanName] = {}
        end
        table.insert(spawnGroups[cleanName], spawnNode:GetPivot().Position)
    end
    for mobName, positions in pairs(spawnGroups) do
        local totalPos = Vector3.new(0, 0, 0)
        local count = #positions
        for _, pos in pairs(positions) do
            totalPos = totalPos + pos
        end
        local midPoint = totalPos / count
        DynamicMobSpawns[mobName] = CFrame.new(midPoint)
        warn("Initialized spawn point for " .. mobName .. "at " .. tostring(DynamicMobSpawns[mobName]))
    end
end


    local trashFruit = nil
    local millionFruit = nil
    local minPrice = math.huge
    local min1MPrice = math.huge
    for _, v in pairs(CommF:InvokeServer("getInventory")) do
        if v.Type == "Blox Fruit" and v.Name ~= "Dough-Dough" then
            if v.Value < minPrice then
                minPrice = v.Value
                trashFruit = v.Name
            end
            if v.Value >= 1000000 and v.Value < min1MPrice and v.Name ~= "Dough-Dough" then
                min1MPrice = v.Value
                millionFruit = v.Name
            end
        end
    end
    local fruitToUse = nil
    if isAdvancedRaid then
        if millionFruit then
            fruitToUse = millionFruit
        else
            FruitSelected = "Ice" 
            fruitToUse = trashFruit
        end
    else
        fruitToUse = trashFruit
    end

    if fruitToUse then
        getgenv().CurrentFarmTask = "Buying Chip"
        CommF:InvokeServer("LoadFruit", fruitToUse)
        task.wait(0.5) 
    end

    if Notify then Notify(FruitSelected) end
    local buyStatus = tonumber(CommF:InvokeServer("RaidsNpc", "Select", FruitSelected))
    if buyStatus ~= 1 then
        return false
    end
    
    return true
end


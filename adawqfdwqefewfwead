function SSS(Pos, donttp)
    if hasSweetChalice() or hasGodChalice() or getgenv().CurrentFarmTask == "Buying Chip" or
        (World3 and CheckBackPack("Red Key") and not CanAwakenDough()) or ScriptStorage.PlayerData.Level.Value <= 10 or getgenv().CurrentFarmTask == "Collecting Fruit" then
        return
    end
    if donttp then return end
    if Pos then
        if GetDistance(Pos) < 200 then
            BypassingTP = false
            return
        end
        local ListPos = {}
        
        -- Dynamically fetch all spawn locations to avoid the buggy static cache
        for _, v7 in pairs(workspace._WorldOrigin.PlayerSpawns:GetChildren()) do
            for _, v9 in pairs(v7:GetChildren()) do
                if v9:IsA("Model") then
                    table.insert(ListPos, v9:GetModelCFrame().p)
                elseif v9:IsA("BasePart") then
                    table.insert(ListPos, v9.Position)
                end
            end
        end
        
        if #ListPos == 0 then
            return
        end
        
        if #ListPos > 1 then
            table.sort(ListPos, function(a, b)
                return GetDistance(a, Pos) < GetDistance(b, Pos)
            end)
        end
        task.wait()
        
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        
        for i, v in pairs(ListPos) do
            if GetDistance(v, Pos) + 200 < GetDistance(Pos, char) and GetDistance(v, char) >= 200 then
                BypassingTP = true
                if CheckBackPack("Special Microchip") then return end
                if char:FindFirstChild("LastSpawnPoint") then char.LastSpawnPoint.Disabled = false end
                local SP, Tag = GetTPLocation(v)
                if char:FindFirstChild('LastSpawnPoint') then char.LastSpawnPoint.Disabled = true end
                game.ReplicatedStorage.Remotes.CommF_:InvokeServer("SetLastSpawnPoint", SP);
                task.wait()
                if game.Players.LocalPlayer.Data.LastSpawnPoint.Value == SP then
                    char.Humanoid.Health = 0
                    if char:FindFirstChild("Head") then char.Head:Destroy() end
                    task.wait()
                    while not IsPlayerAlive() do
                        task.wait()
                    end
                    return SSS(Pos)
                end
            end
        end
        BypassingTP = false
        if char:FindFirstChild('LastSpawnPoint') then char.LastSpawnPoint.Disabled = false end
    end
end



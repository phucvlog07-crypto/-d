local SpinIncrement = 0
LastSpin = tick()
 function CalDirection(Pos)
    if SpinIncrement > 6000 then SpinIncrement = 60 end
    SpinIncrement = SpinIncrement + (tick() - LastSpin > 0.5 and 90 or 0)
    LastSpin = tick() - LastSpin > 0.5 and tick() or LastSpin
    local SpinX = Pos.X + math.sin(math.rad(SpinIncrement + 360)) * 30
    local SpinZ = Pos.Z + math.cos(math.rad(SpinIncrement + 360)) * 30
    return CFrame.new(SpinX, Pos.Y, SpinZ)
end
